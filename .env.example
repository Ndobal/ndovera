# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Web frontend API base URL. Leave empty when the frontend and backend are served from the same origin.
VITE_API_URL=""

# AMI backend API base URL used by the unified frontend for global-role features.
VITE_SUPER_ADMIN_API_URL="https://super-admin-api.example.com"

# Optional dedicated WebSocket signaling endpoint for WebRTC features.
VITE_SIGNALING_WS_URL="wss://realtime.example.com"

# Optional public asset base for super-admin proof/document links.
VITE_PUBLIC_ASSET_BASE_URL="https://assets.example.com"

# YouTube OAuth client settings used for classroom material videos, live class recordings,
# and shared-file video uploads. Video uploads stay disabled until these are configured.
YOUTUBE_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
YOUTUBE_REFRESH_TOKEN=""
YOUTUBE_REDIRECT_URI="https://www.ndovera.com/api/youtube/callback"

# Optional YouTube upload tuning.
YOUTUBE_UPLOAD_PRIVACY_STATUS="unlisted"
YOUTUBE_UPLOAD_CATEGORY_ID="27"
YOUTUBE_UPLOAD_DEFAULT_TAGS="ndovera,education"
YOUTUBE_UPLOAD_NOTIFY_SUBSCRIBERS="false"

# Optional rich media upload size limit in megabytes for server-side disk uploads.
RICH_MEDIA_UPLOAD_LIMIT_MB="512"

# OpenAI backend-only settings for Ndovera AI features.
# Never expose these values in frontend code.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL_LOW="gpt-4o-mini"
OPENAI_MODEL_HIGH="gpt-4o-mini"
OPENAI_MODEL_ANALYSIS="gpt-4o-mini"
AI_RATE_LIMIT_PER_HOUR="20"
AI_RATE_LIMIT_MINUTES="60"
