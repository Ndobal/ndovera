{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "frontend-build-validation",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "frontend-build-from-root",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "pages-deploy-frontend",
			"type": "shell",
			"command": "${workspaceFolder}/frontend/backend/node_modules/.bin/wrangler.cmd",
			"args": [
				"pages",
				"deploy",
				"build",
				"--project-name",
				"ndovera",
				"--branch",
				"main",
				"--commit-dirty=true"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "frontend-build-public-onboarding",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "backend-build-public-onboarding",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend/backend"
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "frontend-dev-server",
			"type": "shell",
			"command": "npm",
			"args": [
				"start"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "install-xlsx-frontend",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"install",
				"xlsx",
				"--save"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "install-xlsx-frontend-explicit",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd /d \"c:\\Users\\HP\\Documents\\projects\\ndovera\\frontend\" && npm install xlsx --save"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}