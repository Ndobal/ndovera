import React, { useState } from 'react';
import api from '../../../services/api';

export default function FarmingModeModule({ role }: { role?: string }) {
  const [resp, setResp] = useState<any>(null);
  return (
    <div>
      <h2 className="text-2xl font-bold text-white">Farming Mode</h2>
      <p className="text-sm text-slate-400">Educational farming mode / school enterprise (stub).</p>
      <div className="mt-4 p-4 bg-slate-900 rounded-lg">Farming stub: track plots, produce, and assignments.</div>
      <div className="mt-4">
        <button onClick={async ()=>setResp(await api.createFarm({ name: 'Frontend Smoke Farm', plot_count: 1, produce: 'Yam', manager_id: 't3' }))} className="px-3 py-2 bg-emerald-600 rounded">Create Farm</button>
        <pre className="mt-2 text-xs">{resp ? JSON.stringify(resp,null,2) : 'No response yet'}</pre>
      </div>
    </div>
  );
}
