NDOVERA_AUTH_SECRET=replace-with-a-long-random-secret
NDOVERA_BOOTSTRAP_ADMIN_NAME=Ndovera Admin
NDOVERA_BOOTSTRAP_ADMIN_ROLE=HOS

SUPER_ADMIN_EMAIL=super-admin@ndovera.com
SUPER_ADMIN_PASSWORD_HASH=$$2a$$12$$replace-with-bcrypt-hash
NDOVERA_SUPER_ADMIN_AUTH_SECRET=replace-with-a-second-long-random-secret
NDOVERA_SUPER_ADMIN_ROLE=Super Admin
NDOVERA_SUPER_ADMIN_NAME=Super Admin

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=strict
TRUST_PROXY=1

NDOVERA_IDENTITY_DB_PATH=/app/storage/ndovera-identity.db
NDOVERA_CHAMPIONSHIP_DB_PATH=/app/storage/ndovera-championship.db
NDOVERA_APP_DB_PATH=/app/storage/ndovera-app.db
NDOVERA_LEGACY_STATE_PATH=/app/storage/identity-state.json

CORS_ORIGIN=https://www.ndovera.com,https://super-admin.ndovera.com